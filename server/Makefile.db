PROJECT_ROOT := ..

# Load vars from ../.env
ifneq ("$(wildcard $(PROJECT_ROOT)/.env)","")
include $(PROJECT_ROOT)/.env
export
endif

# Normalize relative paths from .env to the project root
DB_DIR := $(abspath $(PROJECT_ROOT)/$(DB_DIR))
BACKUP_DIR := $(abspath $(PROJECT_ROOT)/$(BACKUP_DIR))

DB_FILE := $(DB_DIR)/gallery.sqlite
SCHEMA_FILE := $(DB_DIR)/schema.sql

BACKUP_FILE ?=

TS := $(shell gdate -u +"%Y%m%dT%H%M%SZ" 2>/dev/null || date +"%Y%m%dT%H%M%SZ")
BACKUP_FILE_DEFAULT := $(BACKUP_DIR)/photo.sqlite.$(TS).bak

.PHONY: init schema clear reset start stop shell backup restore

init: $(DB_DIR) $(SCHEMA_FILE)
	@echo "Initializing DB at $(DB_FILE)"
	@sqlite3 "$(DB_FILE)" ".read $(SCHEMA_FILE)"

schema: $(SCHEMA_FILE)
	@sqlite3 :memory: ".read $(SCHEMA_FILE)" >/dev/null

shell: init
	@sqlite3 "$(DB_FILE)"

reset: $(DB_DIR)
	@echo "Resetting DB (deleting $(DB_FILE) if it exists)"
	@rm -f "$(DB_FILE)"
	@$(MAKE) --no-print-directory init -f Makefile.db

clear: reset

$(DB_DIR) $(BACKUP_DIR):
	mkdir -p $@

backup: $(DB_DIR) $(BACKUP_DIR)
	@echo "Creating backup -> $(BACKUP_FILE_DEFAULT)"
	@cp -f "$(DB_FILE)" "$(BACKUP_FILE_DEFAULT)"
	@echo "Backup created: $(BACKUP_FILE_DEFAULT)"

restore: $(BACKUP_DIR) init
	@if [ -z "$(BACKUP_FILE)" ]; then \
		echo "ERROR: set BACKUP_FILE, e.g. make -f Makefile.db restore BACKUP_FILE=backups/foo.bak"; \
		exit 1; \
	fi
	@if [ ! -f "$(BACKUP_FILE)" ]; then \
		echo "ERROR: backup file not found: $(BACKUP_FILE)"; \
		exit 1; \
	fi
	@echo "Restoring DB from $(BACKUP_FILE)"
	@cp -f "$(BACKUP_FILE)" "$(DB_FILE)"
	@echo "Restore complete."

